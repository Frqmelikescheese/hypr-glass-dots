{
    "layer": "top",
    "position": "top",
    "height": 40,
    "margin": "5 10 0 10",
    "spacing": 4,
    "modules-left": [
        "hyprland/workspaces",
        "custom/cava"
    ],
    "modules-center": [
        "clock",
        "custom/media"
    ],
    "modules-right": [
        "tray",
        "pulseaudio",
        "backlight",
        "cpu",
        "memory",
        "network",
        "battery",
        "custom/power"
    ],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}",
        "on-click": "activate"
    },

    "custom/cava": {
        "exec": "/home/frqme/.config/waybar/scripts/waybar-cava.sh",
        "format": "{}",
        "tooltip": false
    },

    "custom/media": {
        "format": "{icon} {text}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "Paused": "ïپ‹",
            "Playing": "ïپŒ"
        },
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next",
        "on-click-middle": "playerctl previous",
        "exec": "/home/frqme/.config/waybar/scripts/mediaplayer.sh 2> /dev/null"
    },

    "clock": {
        "format": "ï€— {:%H:%M}",
        "format-alt": "َ°ƒ­ {:%Y-%m-%d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں",
        "format-icons": {
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "pavucontrol",
        "scroll-step": 5
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    "cpu": {
        "interval": 10,
        "format": "ï‹› {usage}%",
        "max-length": 10,
        "states": {
            "critical": 90
        }
    },

    "memory": {
        "interval": 30,
        "format": "ï”¸ {}%",
        "format-alt":"ï”¸ {used}GiB",
        "max-length": 10,
        "states": {
            "critical": 80
        }
    },

    "network": {
        "format-wifi": "ï‡« {signalStrength}%",
        "format-ethernet": "َ°ˆ€",
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "َ°–ھ",
        "on-click": "nm-connection-editor"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "ï‡¦ {capacity}%",
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    "custom/power": {
        "format": "ï€‘",
        "on-click": "~/.config/hypr/scripts/powermenu.sh",
        "tooltip": false
    }
}
