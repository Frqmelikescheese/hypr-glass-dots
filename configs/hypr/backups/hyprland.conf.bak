
# ----------------------------------------------------- 
# Hyprland Config - By Gemini, FINAL STABLE v5 (v0.54+ Optimized)
# ----------------------------------------------------- 

# MONITOR
# Left: Laptop (Dell G16) - 2560x1600 @ 165Hz (Your hardware says 165Hz max)
monitor=eDP-1,2560x1600@165,0x0,1
# Middle: LG UltraGear (Main) - 1920x1080 @ 144Hz
monitor=HDMI-A-1,1920x1080@144,2560x0,1
# Right: Philips - 1920x1080 @ 75Hz
monitor=DP-1,1920x1080@75,4480x0,1

# ENVIRONMENT
env = XCURSOR_SIZE,24
env = GTK_THEME,Adwaita-dark
env = XDG_CURRENT_DESKTOP,Hyprland
env = XDG_SESSION_TYPE,wayland
env = XDG_SESSION_DESKTOP,Hyprland

# AUTOSTART
exec-once = pkill hyprpaper; hyprpaper
exec-once = pkill waybar; ~/.config/waybar/launch.sh
exec-once = dunst
exec-once = nm-applet --indicator
# Force Dark Theme via Gsettings
exec-once = gsettings set org.gnome.desktop.interface gtk-theme 'Adwaita-dark'
exec-once = gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'

# PROGRAMS
$terminal = kitty
$fileManager = thunar
$menu = rofi -show drun

# INPUT
input {
    kb_layout = us
    follow_mouse = 1
    sensitivity = 0 
    
    touchpad {
        natural_scroll = true
    }
}

# GENERAL
general {
    gaps_in = 5
    gaps_out = 10
    border_size = 2
    # FULLY WHITE GRADIENT BORDER
    col.active_border = rgba(ffffffff) rgba(ffffffff) 45deg
    col.inactive_border = rgba(595959aa)
    layout = dwindle
}

# DECORATION
decoration {
    rounding = 10
    
    blur {
        enabled = true
        size = 8
        passes = 3
    }
    
    shadow {
        enabled = true
        range = 4
        render_power = 3
        color = rgba(1a1a1aee)
    }
}

# ANIMATIONS (Snappier/Faster)
animations {
    enabled = yes
    bezier = myBezier, 0.05, 0.9, 0.1, 1.05
    animation = windows, 1, 4, myBezier 
    animation = windowsOut, 1, 4, default, popin 80%
    animation = border, 1, 5, default
    animation = fade, 1, 4, default
    animation = workspaces, 1, 4, default, slide
}

# LAYOUTS
dwindle {
    pseudotile = yes
    preserve_split = yes
}

# MISC
misc {
    force_default_wallpaper = 0
    vfr = true
}

# GESTURE
gesture = 3, horizontal, workspace

# WINDOW RULES
windowrule {
    name = pavucontrol-float
    match:class = ^(pavucontrol)$
    float = on
}

windowrule {
    name = blueman-float
    match:class = ^(blueman-manager)$
    float = on
}

windowrule {
    name = nm-float
    match:class = ^(nm-connection-editor)$
    float = on
}

windowrule {
    name = kitty-opacity
    match:class = ^(kitty)$
    opacity = 0.8
}

windowrule {
    name = thunar-opacity
    match:class = ^(thunar)$
    opacity = 0.85
}

# LAYER RULES (Fixed syntax with match:namespace)
layerrule = blur on, match:namespace ^(rofi)$
layerrule = blur on, match:namespace ^(waybar)$

# KEYBINDINGS
$mainMod = SUPER
bind = $mainMod, Q, exec, $terminal
bind = $mainMod, C, killactive,
bind = $mainMod, M, exit,
bind = $mainMod, E, exec, $fileManager
bind = $mainMod, R, exec, $menu
bind = SUPER, 0, exec, kitty --title tty-clock -e tty-clock -c -C 4
bind = $mainMod, 1, workspace, 1
bind = SUPER, T, exec, firefox
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = , Print, exec, grimblast save output
bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow
bind = SUPER, V, togglefloating, 
# Scroll up to grow the window
binde = SUPER, mouse_up, resizeactive, 50 50
# Scroll down to shrink the window
binde = SUPER, mouse_down, resizeactive, -30 -30

# Brightness and Audio
binde=, XF86MonBrightnessUp, exec, brightnessctl set +5%
binde=, XF86MonBrightnessDown, exec, brightnessctl set 5%-
binde=, XF86AudioRaiseVolume, exec, wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+
binde=, XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bind=, XF86AudioMute, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle

# Custom Brightness Keybinds (SUPER + / -)
binde = $mainMod, equal, exec, brightnessctl set +15%
binde = $mainMod, minus, exec, brightnessctl set 15%-
binde = $mainMod, plus, exec, brightnessctl set +15%
env = GTK_THEME,Adwaita:dark
exec-once = dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
